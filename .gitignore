# =============================================================================
# Cache – keep processed feature pickles, exclude raw / large files
# =============================================================================

# FastF1 per-session HTTP cache (year folders, ~1–3 GB each)
cache/2018/
cache/2019/
cache/2020/
cache/2021/
cache/2022/
cache/2023/
cache/2024/
cache/2025/
cache/2026/
cache/2027/

# FastF1 SQLite HTTP cache (~4.3 GB)
cache/fastf1_http_cache.sqlite

# OpenF1 raw cache
cache/openf1/

# Raw results (regenerated by loaders.py on first run)
cache/raw_results_2018_2025.pkl

# Tracked / shared feature caches (small, safe to commit):
#   cache/practice_features.pkl       (~1.3 MB)
#   cache/qualifying_results.pkl      (~152 KB)
#   cache/data_with_all_features.pkl  (~3.4 MB)

# =============================================================================
# Trained models
# =============================================================================
models/*.pkl

# =============================================================================
# Python
# =============================================================================
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.so
*.egg
*.egg-info/
dist/
build/
.eggs/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# =============================================================================
# Environments
# =============================================================================
.venv/
venv/
env/
.env
.env.*

# =============================================================================
# Jupyter
# =============================================================================
.ipynb_checkpoints/
*.ipynb~

# =============================================================================
# OS / editor
# =============================================================================
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp
*.swo
